{
 "doctype": "DocType",
 "name": "Student Attendance",
 "module": "Sms",
 "autoname": "ATT-.YYYY.-.#####",
 "naming_rule": "Expression",
 "track_changes": 1,
 "field_order": [
  "student",
  "student_name",
  "course",
  "department",
  "academic_year",
  "batch",
  "column_break_1",
  "attendance_date",
  "attendance_hour",
  "status",
  "remarks"
 ],
 "fields": [
  {
   "fieldname": "student",
   "fieldtype": "Link",
   "label": "Student",
   "options": "Student",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "student_name",
   "fieldtype": "Data",
   "label": "Student Name",
   "fetch_from": "student.full_name",
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "course",
   "fieldtype": "Link",
   "label": "Course",
   "options": "Course",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "department",
   "fieldtype": "Link",
   "label": "Department",
   "options": "Department",
   "in_list_view": 1
  },
  {
   "fieldname": "academic_year",
   "fieldtype": "Link",
   "label": "Academic Year",
   "options": "Academic Year",
   "in_list_view": 1
  },
  {
   "fieldname": "batch",
   "fieldtype": "Data",
   "label": "Batch",
   "in_list_view": 1
  },
  {
   "fieldname": "column_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "attendance_date",
   "fieldtype": "Date",
   "label": "Attendance Date",
   "reqd": 1,
   "default": "Today",
   "in_list_view": 1
  },
  {
   "fieldname": "attendance_hour",
   "fieldtype": "Select",
   "label": "Hour",
   "options": "\n1\n2\n3\n4\n5",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "\nPresent\nAbsent\nLate\nExcused",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "remarks",
   "fieldtype": "Small Text",
   "label": "Remarks"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1
  }
 ]
}
