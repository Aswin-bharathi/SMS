{
 "doctype": "DocType",
 "name": "Student",
 "module": "Sms",
 "autoname": "field:student_id",
 "naming_rule": "By fieldname",
 "title_field": "full_name",
 "image_field": "student_image",
 "search_fields": "full_name,student_id,email",
 "track_changes": 1,
 "field_order": [
  "section_personal",
  "student_id",
  "first_name",
  "last_name",
  "full_name",
  "student_image",
  "column_break_1",
  "date_of_birth",
  "gender",
  "blood_group",
  "nationality",
  "section_contact",
  "email",
  "phone",
  "address",
  "column_break_2",
  "guardian_name",
  "guardian_phone",
  "section_academic",
  "program_level",
  "program",
  "department",
  "academic_year",
  "batch",
  "current_semester",
  "column_break_3",
  "enrollment_date",
  "status"
 ],
 "fields": [
  {
   "fieldname": "section_personal",
   "fieldtype": "Section Break",
   "label": "Personal Information"
  },
  {
   "fieldname": "student_id",
   "fieldtype": "Data",
   "label": "Student ID",
   "reqd": 1,
   "unique": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "first_name",
   "fieldtype": "Data",
   "label": "First Name",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "last_name",
   "fieldtype": "Data",
   "label": "Last Name",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "full_name",
   "fieldtype": "Data",
   "label": "Full Name",
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "student_image",
   "fieldtype": "Attach Image",
   "label": "Student Photo"
  },
  {
   "fieldname": "column_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "date_of_birth",
   "fieldtype": "Date",
   "label": "Date of Birth",
   "reqd": 1
  },
  {
   "fieldname": "gender",
   "fieldtype": "Select",
   "label": "Gender",
   "options": "\nMale\nFemale\nOther",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "blood_group",
   "fieldtype": "Select",
   "label": "Blood Group",
   "options": "\nA+\nA-\nB+\nB-\nO+\nO-\nAB+\nAB-"
  },
  {
   "fieldname": "nationality",
   "fieldtype": "Data",
   "label": "Nationality",
   "default": "Indian"
  },
  {
   "fieldname": "section_contact",
   "fieldtype": "Section Break",
   "label": "Contact Information"
  },
  {
   "fieldname": "email",
   "fieldtype": "Data",
   "label": "Email",
   "options": "Email",
   "in_list_view": 1
  },
  {
   "fieldname": "phone",
   "fieldtype": "Data",
   "label": "Phone",
   "options": "Phone"
  },
  {
   "fieldname": "address",
   "fieldtype": "Small Text",
   "label": "Address"
  },
  {
   "fieldname": "column_break_2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "guardian_name",
   "fieldtype": "Data",
   "label": "Guardian Name"
  },
  {
   "fieldname": "guardian_phone",
   "fieldtype": "Data",
   "label": "Guardian Phone",
   "options": "Phone"
  },
  {
   "fieldname": "section_academic",
   "fieldtype": "Section Break",
   "label": "Academic Information"
  },
  {
   "fieldname": "program_level",
   "fieldtype": "Select",
   "label": "Program Level",
   "options": "\nUG\nPG",
   "default": "UG",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "program",
   "fieldtype": "Link",
   "label": "Program",
   "options": "Program",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "department",
   "fieldtype": "Link",
   "label": "Department",
   "options": "Department"
  },
  {
   "fieldname": "academic_year",
   "fieldtype": "Link",
   "label": "Academic Year",
   "options": "Academic Year"
  },
  {
   "fieldname": "batch",
   "fieldtype": "Data",
   "label": "Batch",
   "in_list_view": 1
  },
  {
   "fieldname": "current_semester",
   "fieldtype": "Select",
   "label": "Current Semester",
   "options": "\n1\n2\n3\n4\n5\n6\n7\n8"
  },
  {
   "fieldname": "column_break_3",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "enrollment_date",
   "fieldtype": "Date",
   "label": "Enrollment Date",
   "default": "Today"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "\nActive\nInactive\nGraduated\nDropped",
   "default": "Active",
   "in_list_view": 1
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "email": 1,
   "export": 1,
   "print": 1,
   "report": 1,
   "share": 1
  }
 ]
}
